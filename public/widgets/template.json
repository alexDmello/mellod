{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "TextBlock",
      "size": "Medium",
      "weight": "Bolder",
      "text": "${title}",
      "color": "Good"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "items": [
            {
              "type": "TextBlock",
              "text": "Completed Stops",
              "wrap": true,
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "size": "ExtraLarge",
              "color": "Good",
              "weight": "Bolder",
              "text": "${completedStops}"
            }
          ],
          "width": "stretch"
        },
        {
          "type": "Column",
          "items": [
            {
              "type": "TextBlock",
              "text": "Total Oil Collected",
              "wrap": true,
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "size": "ExtraLarge",
              "color": "Accent",
              "weight": "Bolder",
              "text": "${totalLiters}"
            }
          ],
          "width": "stretch"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open Route Portal",
      "url": "${actionUrl}"
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5"
}
