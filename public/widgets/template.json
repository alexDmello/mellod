{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "TextBlock",
      "size": "Medium",
      "weight": "Bolder",
      "text": "${title}",
      "color": "Attention"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "items": [
            {
              "type": "TextBlock",
              "text": "Completed Stops",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "size": "ExtraLarge",
              "color": "Good",
              "weight": "Bolder",
              "text": "${completedStops}"
            }
          ],
          "width": "stretch"
        },
        {
          "type": "Column",
          "items": [
            {
              "type": "TextBlock",
              "text": "Total Liters",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "size": "ExtraLarge",
              "color": "Accent",
              "weight": "Bolder",
              "text": "${totalLiters} L"
            }
          ],
          "width": "stretch"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5"
}
